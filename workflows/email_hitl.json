    {
      "parameters": {
        "jsCode": "// Read brand voice system prompt from env or hardcode here\nconst systemPrompt = `You are a professional customer support agent.\nYou MUST return a valid JSON object only:\n{\n  \"draft\": \"<reply text>\",\n  \"confidence\": <0.0-1.0>,\n  \"flags\": [\"pricing\"|\"refund\"|\"delivery_promise\"|\"legal_claim\"|\"medical\"|\"out_of_scope\"]\n}\nTone: polite, clear, formal. Never promise delivery dates, never guarantee refunds.\nConfidence: start at 1.0, subtract 0.20 for pricing/refund, 0.15 for deadlines/legal/medical, 0.10 for out-of-scope.`;\n\nconst email = $input.first().json;\nreturn [{\n  json: {\n    gmail_id: email.id,\n    from_address: email.From,\n    subject: email.Subject,\n    incoming_body: email.text || email.snippet || '',\n    system_prompt: systemPrompt,\n    user_message: `Customer email from: ${email.from}\\nSubject: ${email.subject}\\n\\n${email.text || email.snippet}`\n  }\n}];"
      },
      "id": "681e5881-d10e-4519-84bc-c47f276091eb",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1184,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const prev = $input.first().json;\n\n// Support Gemini, Moonshot/OpenAI response shapes\nconst rawText = prev.content?.parts?.[0]?.text          // Gemini\n  || prev.choices?.[0]?.message?.content                 // OpenAI/Moonshot\n  || prev.text\n  || '';\n\nlet parsed;\ntry {\n  const cleaned = rawText.replace(/```json\\s*/g, '').replace(/```\\s*/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  parsed = { draft: rawText, confidence: 0.3, flags: ['parse_error'] };\n}\n\nconst ctx = $node['Build Prompt'].json;\n\nreturn [{\n  json: {\n    gmail_id: ctx.gmail_id,\n    from_address: ctx.from_address,\n    subject: ctx.subject,\n    incoming_body: ctx.incoming_body,\n    ai_draft: parsed.draft,\n    confidence: parsed.confidence,\n    flags: parsed.flags ?? [],\n    resume_url: $execution.resumeUrl\n  }\n}];\n"
      },
      "id": "b23e5296-21a1-469c-989f-b6d73de6f82b",
      "name": "Parse Response",
      "type": "n8n-nodes-base.code",
