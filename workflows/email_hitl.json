        "jsCode": "const ctx = $node['Parse Response'].json;\nconst dbRow = $input.first().json;\n\nreturn [{\n  json: {\n    job_id: dbRow.id,\n    payload: {\n      // chat_id: $env.TELEGRAM_CHAT_ID,\n      text: `📧 <b>Review Required</b>\\n\\n<b>From:</b> ${ctx.from_address}\\n<b>Subject:</b> ${ctx.subject}\\n<b>Confidence:</b> ${ctx.confidence}\\n<b>Flags:</b> ${ctx.flags.join(', ') || 'none'}\\n\\n<b>Draft:</b>\\n${ctx.ai_draft}`,\n      parse_mode: 'HTML',\n      reply_markup: {\n        inline_keyboard: [[\n          { text: '✅ Approve', url: $execution.resumeUrl + '?decision=approve' },\n          { text: '❌ Reject', url: $execution.resumeUrl + '?decision=reject' }\n        ]]\n      }\n    }\n  }\n}];"
