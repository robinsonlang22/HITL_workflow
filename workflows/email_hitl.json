        "query": "INSERT INTO jobs (gmail_id, from_address, subject, incoming_body, ai_draft, confidence, flags, resume_url, status) VALUES ($1, $2, $3, $4, $5, $6, $7::jsonb, $8, 'pending') ON CONFLICT (gmail_id) DO UPDATE SET ai_draft=$5, confidence=$6, resume_url=$8, status='pending' RETURNING id",
        "options": {
          "queryReplacement": "={{ [ $json.gmail_id, $json.from_address, $json.subject, $json.incoming_body, $json.ai_draft, $json.confidence, JSON.stringify($json.flags), $json.resume_url ] }}"
